# Xiaomi MiMo API Configuration
# Get your API key at: https://platform.xiaomimimo.com/
MIMO_API_KEY=your_mimo_api_key_here

# Optional: Custom endpoint (for enterprise/self-hosted MiMo)
MIMO_BASE_URL=https://api.xiaomimimo.com/v1

# Optional: Model override (default: MiMo-Max)
MIMO_MODEL=mimo-max-2026

# Agent settings
AGENT_MAX_ITERATIONS=50
AGENT_TIMEOUT=120
AGENT_TEMPERATURE=0.7

# Logging
LOG_LEVEL=INFO
LOG_FILE=mimo.log
